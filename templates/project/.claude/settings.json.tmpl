{
  "model": "sonnet",
  "permissionMode": "default",
  "autoMemory": false,
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5"
  },
  "permissions": {
    "allow": [
      "npm test",
      "npm run dev",
      "npm run build",
      "npm run lint",
      "npm run test:*",
      "npx depcheck",
      "git status",
      "git diff",
      "git diff *",
      "git add *",
      "git commit *",
      "git log *",
      "git checkout -b *",
      "git branch *",
      "tsc --noEmit",
      "eslint *",
      "curl -s * localhost:3100/*"
    ],
    "deny": [
      ".env",
      "rm -rf",
      "rm -r",
      "sudo",
      "curl * | bash",
      "git push *",
      "git reset --hard *",
      "git checkout -- *",
      "git merge * main",
      "git merge main *"
    ]
  },
  "compaction": {
    "threshold": 0.9
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== PRIMER ===' && cat .avner/primer.md 2>/dev/null || echo 'No primer.md found.'"
          },
          {
            "type": "command",
            "command": "echo '=== GIT CONTEXT ===' && git log --oneline -5 2>/dev/null && echo '---' && git diff --stat HEAD~1 2>/dev/null && echo '---' && git status --short 2>/dev/null || echo 'No git context.'"
          },
          {
            "type": "command",
            "command": "echo '=== DISPATCH ===' && cat .avner/4_operations/DISPATCH.md 2>/dev/null || echo 'No active dispatch.'"
          },
          {
            "type": "command",
            "command": "if [ -f .avner/4_operations/APPROVAL_PENDING.md ] && grep -q 'Status: PENDING' .avner/4_operations/APPROVAL_PENDING.md 2>/dev/null; then echo '⚠️ Pending approvals require human resolution. See .avner/4_operations/APPROVAL_PENDING.md'; fi"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== POST-COMPACTION RESTORE ===' && cat .avner/primer.md 2>/dev/null && echo '---' && cat .avner/4_operations/DISPATCH.md 2>/dev/null && echo '---' && git log --oneline -5 2>/dev/null && echo '=== Read API_CONTRACTS.md and DB_SCHEMA.md before any /core or /deploy work. ==='"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Session ending. Remember to update primer.md and hindsight.md if needed.'"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cp .avner/primer.md .avner/primer.md.bak 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit'; then (npm run lint 2>/dev/null && tsc --noEmit 2>/dev/null) || true; fi"
          },
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git commit'; then if ! grep -E -q '^(APPROVE|FIX-BYPASS)' .avner/4_operations/last_vision_check.txt 2>/dev/null; then DISPATCH_EVIDENCE=$(grep -oE '(APPROVE|FIX-BYPASS) [0-9]+' .avner/4_operations/DISPATCH.md 2>/dev/null | head -1); if [ -z \"$DISPATCH_EVIDENCE\" ]; then echo 'COMMIT BLOCKED: No vision evidence in last_vision_check.txt or DISPATCH.md'; exit 2; fi; fi; fi"
          },
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -q 'git merge'; then if ! grep -E -q '^GATE_PASS' .avner/4_operations/gate_pass.txt 2>/dev/null; then echo 'MERGE BLOCKED: No gate_pass.txt — review not passed.'; exit 2; fi; fi"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "if echo \"$CLAUDE_TOOL_INPUT\" | grep -qE '(CLAUDE\\.md)'; then echo 'DNA SAFETY: CLAUDE.md requires explicit human approval + visible diffs before modification.'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "npm run lint 2>/dev/null || true"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "source .paperclip/lib/paperclip.sh 2>/dev/null && paperclip_heartbeat || true"
          }
        ]
      }
    ]
  }
}
