# Paperclip Configuration — {{PROJECT_NAME}}
# Docs: https://docs.paperclip.ing/api/overview

# --- Connection ---
api_url: http://localhost:3100/api
company_id: ""

# --- Agent IDs (set after `paperclipai onboard`) ---
agents:
  ceo_codex: ""
  claude_code: ""
  codex_review: ""

# --- Auth ---
# API key loaded from env: PAPERCLIP_API_KEY
api_key_env_var: PAPERCLIP_API_KEY

# --- Feature flags ---
heartbeats:
  enabled: true
approvals:
  enabled: true
cost_events:
  enabled: true

# --- Dry-run mode ---
# When true, log payloads to stderr instead of making HTTP calls.
# Set false only when Paperclip server is running and onboarded.
dry_run: true

# --- Budget ---
monthly_budget_usd: 100
per_task_cap:
  LOW: 2.00
  MEDIUM: 8.00
  HIGH: 25.00

# --- Approval triggers ---
require_human_approval:
  - HIGH risk task completion
  - Council NO-GO verdict
  - Deploy readiness
  - Budget 80% threshold
